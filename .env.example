# ─── WINGO ORACLE BOT — Environment Variables ───────────────────
# Copy this to .env and fill in your values
# NEVER commit .env to GitHub

# Your Telegram Bot Token (get from @BotFather)
BOT_TOKEN=YOUR_NEW_BOT_TOKEN_HERE

# Your Telegram User ID (admin IDs, comma-separated)
# Get your ID by messaging @userinfobot
ADMIN_IDS=123456789,987654321

# Firebase Service Account JSON (stringified)
# OR place serviceAccountKey.json in same folder as bot.js
FIREBASE_CRED={"type":"service_account","project_id":"gaineo",...}
